# Copia este archivo como .env y ajusta valores segun el entorno.

# Clave de Flask/JWT
FLASK_SECRET_KEY=dev-key-cambiar-en-produccion

# Carpeta persistente para JSON (recomendado fuera del repo)
# Ejemplo Windows:
# APP_DATA_DIR=C:\starlink_runner_data
APP_DATA_DIR=

# Ruta opcional para usuarios de login (si no se define, usa APP_DATA_DIR/login.json)
# LOGIN_USERS_FILE=
