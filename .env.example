# Copia este archivo como .env y ajusta valores segun el entorno.

# Clave de Flask/JWT
FLASK_SECRET_KEY=dev-key-cambiar-en-produccion

# Carpeta persistente para JSON (recomendado fuera del repo)
# Ejemplo Windows:
# APP_DATA_DIR=C:\starlink_runner_data
# Ejemplo Render (disco persistente montado en /var/data):
# APP_DATA_DIR=/var/data/runners_starlink_data
APP_DATA_DIR=

# Ruta opcional para usuarios de login (si no se define, usa APP_DATA_DIR/login.json)
# LOGIN_USERS_FILE=

# Postgres (Render u otro)
# Puedes usar DATABASE_URL o variables separadas
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=5432
# DB_SSLMODE=require
# DB_BOOTSTRAP_FROM_JSON=1
